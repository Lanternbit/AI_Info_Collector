<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AI 프론티어 브리핑 — {{ date_str }}</title>
<style>
:root {
  color-scheme: light dark;
  --bg:#ffffff; --fg:#1c1c21; --muted:#6b6b76; --card:#f5f5f7; --border:#e4e4ea;
  --accent:#4f46e5; --accent-soft:#eef0ff; --warn-bg:#fff4e5; --warn-fg:#8a5300;
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg:#101014; --fg:#e9e9ee; --muted:#9a9aa6; --card:#1a1a21; --border:#2a2a34;
    --accent:#8f8ffa; --accent-soft:#1e1e3a; --warn-bg:#3a2c10; --warn-fg:#ffce7a;
  }
}
* { box-sizing:border-box; margin:0; padding:0; }
body { background:var(--bg); color:var(--fg); font-family:system-ui,-apple-system,"Segoe UI","Malgun Gothic",sans-serif; line-height:1.65; }
.wrap { max-width:800px; margin:0 auto; padding:28px 18px 72px; }
header h1 { font-size:1.5rem; letter-spacing:-0.02em; }
header .date { color:var(--muted); margin-top:2px; }
nav.archive { margin-top:10px; font-size:0.85rem; color:var(--muted); }
nav.archive a { color:var(--muted); text-decoration:none; margin-right:8px; }
nav.archive a:hover { color:var(--accent); }
.daily-summary { background:var(--accent-soft); border-radius:12px; padding:16px 18px; margin-top:20px; font-size:0.97rem; }
.daily-summary strong { color:var(--accent); display:block; margin-bottom:6px; font-size:0.85rem; letter-spacing:0.02em; }
nav.toc { display:flex; flex-wrap:wrap; gap:6px; margin-top:16px; }
nav.toc a { font-size:0.82rem; padding:4px 12px; border-radius:99px; border:1px solid var(--border); color:var(--muted); text-decoration:none; }
nav.toc a:hover { color:var(--accent); border-color:var(--accent); }
nav.toc a b { color:var(--fg); font-weight:600; }
.banner { background:var(--warn-bg); color:var(--warn-fg); border-radius:10px; padding:10px 14px; margin:18px 0 0; font-size:0.9rem; }
section { margin-top:36px; }
section > h2 { font-size:1.1rem; padding-bottom:8px; border-bottom:2px solid var(--border); letter-spacing:-0.01em; }
section > h2 .cnt { color:var(--muted); font-weight:400; font-size:0.85rem; }
.item { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:14px 16px; margin-top:12px; }
.item h3 { font-size:1rem; font-weight:600; }
.item h3 a { color:var(--fg); text-decoration:none; }
.item h3 a:hover { color:var(--accent); }
.meta { display:flex; flex-wrap:wrap; gap:6px; margin-top:6px; }
.badge { font-size:0.72rem; padding:2px 8px; border-radius:99px; background:var(--bg); border:1px solid var(--border); color:var(--muted); }
.badge.imp { color:var(--accent); border-color:var(--accent); font-weight:600; }
.summary { margin-top:8px; font-size:0.93rem; }
.why { margin-top:8px; font-size:0.88rem; color:var(--muted); border-left:3px solid var(--accent); padding:2px 0 2px 10px; }
.headline .item { border-left:4px solid var(--accent); }
details.more { margin-top:12px; }
details.more summary { cursor:pointer; color:var(--muted); font-size:0.88rem; padding:6px 2px; user-select:none; }
details.more summary:hover { color:var(--accent); }
details.reader { margin-top:10px; }
details.reader summary { cursor:pointer; color:var(--accent); font-size:0.85rem; user-select:none; }
.reader-body { white-space:pre-line; margin-top:8px; font-size:0.9rem; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:12px 14px; max-height:65vh; overflow-y:auto; }
a.badge { text-decoration:none; }
a.badge:hover { color:var(--accent); border-color:var(--accent); }
ul.compact { list-style:none; margin-top:4px; }
ul.compact li { padding:7px 2px; border-bottom:1px solid var(--border); font-size:0.9rem; display:flex; gap:8px; align-items:baseline; }
ul.compact li:last-child { border-bottom:none; }
ul.compact a { color:var(--fg); text-decoration:none; flex:1; min-width:0; }
ul.compact a:hover { color:var(--accent); }
ul.compact .src { color:var(--muted); font-size:0.75rem; white-space:nowrap; }
footer { margin-top:48px; padding-top:16px; border-top:1px solid var(--border); font-size:0.82rem; color:var(--muted); }
footer ul { list-style:none; margin-top:8px; display:flex; flex-wrap:wrap; gap:4px 14px; }
footer .fail { color:#c0392b; }
.empty { color:var(--muted); margin-top:14px; }
</style>
</head>
<body>
<div class="wrap">
<header>
  <h1>AI 프론티어 브리핑</h1>
  <div class="date">{{ date_str }} · 오늘 {{ total }}건</div>
  <nav class="archive">
    <a href="{{ home_href }}">최신</a>
    {%- for d in archive_dates[:14] %}
    <a href="{{ prefix }}{{ d }}.html">{{ d[5:] }}</a>
    {%- endfor %}
    {% if archive_dates | length > 14 %}<a href="{{ prefix }}index.html">전체 ›</a>{% endif %}
  </nav>
  {% if daily_summary %}
  <div class="daily-summary"><strong>오늘의 요약</strong>{{ daily_summary }}</div>
  {% endif %}
  {% if toc %}
  <nav class="toc">
    <a href="#headlines"><b>헤드라인</b></a>
    {%- for t in toc %}
    <a href="#{{ t.anchor }}">{{ t.label }} <b>{{ t.count }}</b></a>
    {%- endfor %}
  </nav>
  {% endif %}
  {% if not llm_ok %}<div class="banner">⚠ 오늘은 LLM 요약에 실패해 원제목만 표시합니다.</div>{% endif %}
</header>

{% macro card(item) -%}
<article class="item">
  <h3><a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.display_title }}</a></h3>
  <div class="meta">
    <span class="badge">{{ item.source }}</span>
    {% if item.category %}<span class="badge">{{ item.category }}</span>{% endif %}
    {% if item.importance %}<span class="badge imp">중요도 {{ item.importance }}</span>{% endif %}
    {% if item.metrics.get("points") %}<span class="badge">▲ {{ item.metrics["points"] }}</span>{% endif %}
    {% if item.metrics.get("upvotes") %}<span class="badge">▲ {{ item.metrics["upvotes"] }}</span>{% endif %}
    {% if item.metrics.get("likes") %}<span class="badge">♥ {{ item.metrics["likes"] }}</span>{% endif %}
    {% if item.discussion_url %}<a class="badge" href="{{ item.discussion_url }}" target="_blank" rel="noopener">💬 토론</a>{% endif %}
  </div>
  {% if item.summary_ko %}<p class="summary">{{ item.summary_ko }}</p>{% endif %}
  {% if item.why_ko %}<p class="why">{{ item.why_ko }}</p>{% endif %}
  {% if item.body and item.body | length >= 300 %}
  <details class="reader">
    <summary>본문 읽기</summary>
    <div class="reader-body">{{ item.body[:6000] }}{% if item.body | length > 6000 %}

… (전체 내용은 원문 링크에서){% endif %}</div>
  </details>
  {% endif %}
</article>
{%- endmacro %}

{% macro compact_list(list_items) -%}
<ul class="compact">
  {% for item in list_items %}
  <li><a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.display_title }}</a><span class="src">{{ item.source }}</span></li>
  {% endfor %}
</ul>
{%- endmacro %}

{% if headlines %}
<section class="headline" id="headlines">
  <h2>오늘의 헤드라인</h2>
  {% for item in headlines %}{{ card(item) }}{% endfor %}
</section>
{% endif %}

{% for s in sections %}
<section id="{{ s.anchor }}">
  <h2>{{ s.name }} <span class="cnt">{{ s.count }}건</span></h2>
  {% for item in s.featured %}{{ card(item) }}{% endfor %}
  {% if s.notable %}{{ compact_list(s.notable) }}{% endif %}
  {% if s.rest %}
  <details class="more">
    <summary>그 외 {{ s.rest | length }}건 보기</summary>
    {{ compact_list(s.rest) }}
  </details>
  {% endif %}
</section>
{% endfor %}

{% if papers_top %}
<section id="papers">
  <h2>오늘의 논문 <span class="cnt">HF Daily Papers · {{ (papers_top | length) + (papers_rest | length) }}건</span></h2>
  {% for item in papers_top %}{{ card(item) }}{% endfor %}
  {% if papers_rest %}
  <details class="more">
    <summary>그 외 논문 {{ papers_rest | length }}건 보기</summary>
    {{ compact_list(papers_rest) }}
  </details>
  {% endif %}
</section>
{% endif %}

{% if unranked %}
<section>
  <h2>수집된 소식 <span class="cnt">요약 없음 · {{ unranked | length }}건</span></h2>
  <details class="more" {% if not llm_ok %}open{% endif %}>
    <summary>목록 보기</summary>
    {{ compact_list(unranked) }}
  </details>
</section>
{% endif %}

{% if not headlines and not sections and not papers_top and not unranked %}
<p class="empty">오늘 새로 수집된 소식이 없습니다.</p>
{% endif %}

<footer>
  {% set ok_count = source_status | selectattr("ok") | list | length %}
  소스 {{ ok_count }}/{{ source_status | length }} 성공 · 생성 {{ generated_at }}
  <ul>
    {% for s in source_status %}
    <li class="{{ 'ok' if s.ok else 'fail' }}">{{ '✓' if s.ok else '✗' }} {{ s.name }} ({{ s.count }}건){% if not s.ok %} — {{ s.error }}{% endif %}</li>
    {% endfor %}
  </ul>
</footer>
</div>
</body>
</html>
