# 로컬 실행용 비밀키 — 실제 값은 .env에 (git 제외됨)

# Gemini (기본 백엔드, 무료) — https://aistudio.google.com 에서 발급, 카드 등록 불필요
GEMINI_API_KEY=AIza...

# Anthropic (llm_provider: anthropic 전환 시에만 필요)
# ANTHROPIC_API_KEY=sk-ant-...

NOTION_TOKEN=ntn_...
NOTION_DATA_SOURCE_ID=
# NOTION_DATABASE_ID를 대신 넣으면 파이프라인이 data_source_id를 자동 조회한다
NOTION_DATABASE_ID=
